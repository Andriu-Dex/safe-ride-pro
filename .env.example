# -----------------------------------------------------------------------------
# Root .env.example
# -----------------------------------------------------------------------------
# This file is a local-development convenience for the monorepo root.
#
# Recommended source of truth:
# - Backend/API variables: apps/api/.env
# - Frontend/Web variables: apps/web/.env.local
# - QA with Docker Compose: .env.qa
#
# Use this root file only if you want to centralize local development values.
# Do not assume every app reads only from here.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Shared local development
# -----------------------------------------------------------------------------
# Public web API base URL used by the Next.js frontend.
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# Public Geoapify key for browser usage.
# Required only if you want real place autocomplete and map preview in /viajes.
NEXT_PUBLIC_GEOAPIFY_API_KEY=""

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------
PORT="3001"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saferidepro"
JWT_SECRET="change-me"
ACCESS_TOKEN_TTL_MINUTES="60"
REFRESH_TOKEN_TTL_DAYS="30"
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES="30"
PASSWORD_RESET_TOKEN_TTL_MINUTES="30"
AUTH_RESEND_COOLDOWN_SECONDS="60"
AUTH_FAILED_ATTEMPT_LIMIT="5"
AUTH_FAILED_ATTEMPT_WINDOW_MINUTES="15"

# Keep this true only for local development without real email delivery.
AUTH_ALLOW_DEBUG_CODES="true"

# -----------------------------------------------------------------------------
# SMTP email delivery
# -----------------------------------------------------------------------------
# Used by the API for verification codes and password reset emails.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="SafeRidePro"

# -----------------------------------------------------------------------------
# External media providers
# -----------------------------------------------------------------------------
# Used by the API for public profile photo uploads.
IMGUR_CLIENT_ID=""
IMGUR_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Seed / bootstrap defaults
# -----------------------------------------------------------------------------
DEFAULT_INSTITUTION_NAME="Universidad Tecnica de Ambato"
DEFAULT_INSTITUTION_CODE="UTA"
DEFAULT_INSTITUTION_DOMAIN="uta.edu.ec"
SUPER_ADMIN_EMAIL="admin@uta.edu.ec"
SUPER_ADMIN_PASSWORD="ChangeMe123!"
SUPER_ADMIN_FULL_NAME="SafeRidePro Super Admin"
SUPER_ADMIN_DOCUMENT_TYPE="NATIONAL_ID"
SUPER_ADMIN_DOCUMENT_NUMBER="0000000000"
