{
  "name": "@saferidepro/shared-types",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc --project tsconfig.json",
    "dev": "node ../../node_modules/typescript/bin/tsc --project tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "echo \"Shared types tests will be added soon\"",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --project tsconfig.json --noEmit",
    "format": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@saferidepro/eslint-config": "workspace:*",
    "@saferidepro/tsconfig": "workspace:*",
    "@types/node": "^22.13.0",
    "eslint": "^9.21.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  }
}
