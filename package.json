{
  "name": "saferidepro",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "qa:up": "docker compose --env-file .env.qa -f docker-compose.qa.yml up -d",
    "qa:up:build": "docker compose --env-file .env.qa -f docker-compose.qa.yml up --build -d",
    "qa:down": "docker compose --env-file .env.qa -f docker-compose.qa.yml down",
    "qa:reset": "docker compose --env-file .env.qa -f docker-compose.qa.yml down -v",
    "qa:logs": "docker compose --env-file .env.qa -f docker-compose.qa.yml logs -f",
    "qa:ps": "docker compose --env-file .env.qa -f docker-compose.qa.yml ps"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
