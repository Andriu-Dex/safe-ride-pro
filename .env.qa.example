# -----------------------------------------------------------------------------
# QA / Docker Compose .env.example
# -----------------------------------------------------------------------------
# This file is intended for docker-compose QA environments.
# Values here are consumed by containers and compose interpolation.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# PostgreSQL container
# -----------------------------------------------------------------------------
POSTGRES_DB=safe_ride_pro_qa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Published ports
# -----------------------------------------------------------------------------
API_PORT=3001
WEB_PORT=3000

# -----------------------------------------------------------------------------
# API runtime inside QA
# -----------------------------------------------------------------------------
JWT_SECRET=qa-jwt-secret
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_RESEND_COOLDOWN_SECONDS=30
AUTH_FAILED_ATTEMPT_LIMIT=5
AUTH_FAILED_ATTEMPT_WINDOW_MINUTES=15

# Keep true only if QA still uses preview/debug auth codes.
AUTH_ALLOW_DEBUG_CODES=true

# -----------------------------------------------------------------------------
# SMTP email delivery
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SafeRidePro

# -----------------------------------------------------------------------------
# Web/API integration
# -----------------------------------------------------------------------------
WEB_APP_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_GEOAPIFY_API_KEY=

# -----------------------------------------------------------------------------
# Seed / bootstrap defaults
# -----------------------------------------------------------------------------
DEFAULT_INSTITUTION_NAME=Universidad Tecnica de Ambato
DEFAULT_INSTITUTION_CODE=UTA
DEFAULT_INSTITUTION_DOMAIN=uta.edu.ec
SUPER_ADMIN_EMAIL=admin@uta.edu.ec
SUPER_ADMIN_PASSWORD=Admin12345
SUPER_ADMIN_FULL_NAME=SafeRidePro Super Admin
SUPER_ADMIN_DOCUMENT_TYPE=NATIONAL_ID
SUPER_ADMIN_DOCUMENT_NUMBER=0000000000
