# -----------------------------------------------------------------------------
# Web .env.example
# -----------------------------------------------------------------------------
# This is the main source of truth for frontend variables during local
# development when running apps/web.
# Only NEXT_PUBLIC_* variables should be exposed to the browser.
# -----------------------------------------------------------------------------

# Backend base URL consumed by the web client.
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# Public Geoapify key used by the trip creation flow for:
# - place autocomplete
# - map preview in Leaflet
# If empty, the app falls back to manual coordinates.
NEXT_PUBLIC_GEOAPIFY_API_KEY=""
