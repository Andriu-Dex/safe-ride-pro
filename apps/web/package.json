{
  "name": "@saferidepro/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "corepack pnpm --filter @saferidepro/shared-types build",
    "dev": "next dev --port 3000",
    "prebuild": "corepack pnpm --filter @saferidepro/shared-types build",
    "build": "next build",
    "prestart": "corepack pnpm --filter @saferidepro/shared-types build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "test": "echo \"Web tests will be added soon\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@saferidepro/shared-types": "workspace:*",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@saferidepro/eslint-config": "workspace:*",
    "@saferidepro/tsconfig": "workspace:*",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.21.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  }
}

