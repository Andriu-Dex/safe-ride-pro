{
  "name": "@saferidepro/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "corepack pnpm --filter @saferidepro/shared-types build",
    "dev": "node ../../scripts/run-web-next.js dev --port 3000",
    "prebuild": "corepack pnpm --filter @saferidepro/shared-types build",
    "build": "node ../../scripts/run-web-next.js build --webpack",
    "prestart": "corepack pnpm --filter @saferidepro/shared-types build",
    "start": "node ../../scripts/run-web-next.js start --port 3000",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/specs/auth-admin.spec.ts e2e/specs/driver-onboarding-trip.spec.ts e2e/specs/passenger-trust-audit.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@saferidepro/shared-types": "workspace:*",
    "leaflet": "^1.9.4",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@saferidepro/eslint-config": "workspace:*",
    "@saferidepro/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.21.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
