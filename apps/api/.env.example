# -----------------------------------------------------------------------------
# API .env.example
# -----------------------------------------------------------------------------
# This is the main source of truth for backend variables during local
# development when running apps/api.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------
PORT="3001"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saferidepro"

# Schema used by real DB integration tests.
TEST_DATABASE_SCHEMA="integration_tests"

JWT_SECRET="change-me"
ACCESS_TOKEN_TTL_MINUTES="60"
REFRESH_TOKEN_TTL_DAYS="30"
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES="30"
PASSWORD_RESET_TOKEN_TTL_MINUTES="30"
AUTH_RESEND_COOLDOWN_SECONDS="60"
AUTH_FAILED_ATTEMPT_LIMIT="5"
AUTH_FAILED_ATTEMPT_WINDOW_MINUTES="15"

# Keep this true only for local development without real email delivery.
AUTH_ALLOW_DEBUG_CODES="true"

# Allowed origins for the web frontend when calling the API directly.
WEB_APP_ORIGINS="http://localhost:3000"

# -----------------------------------------------------------------------------
# SMTP email delivery
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="SafeRidePro"

# -----------------------------------------------------------------------------
# External media providers
# -----------------------------------------------------------------------------
# Used for public profile photo uploads.
IMGUR_CLIENT_ID=""
IMGUR_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Seed / bootstrap defaults
# -----------------------------------------------------------------------------
DEFAULT_INSTITUTION_NAME="Universidad Tecnica de Ambato"
DEFAULT_INSTITUTION_CODE="UTA"
DEFAULT_INSTITUTION_DOMAIN="uta.edu.ec"
SUPER_ADMIN_EMAIL="admin@uta.edu.ec"
SUPER_ADMIN_PASSWORD="ChangeMe123!"
SUPER_ADMIN_FULL_NAME="SafeRidePro Super Admin"
SUPER_ADMIN_DOCUMENT_TYPE="NATIONAL_ID"
SUPER_ADMIN_DOCUMENT_NUMBER="0000000000"
