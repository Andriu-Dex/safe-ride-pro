{
  "name": "@saferidepro/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "corepack pnpm --filter @saferidepro/shared-types build",
    "dev": "nest start --watch",
    "prebuild": "corepack pnpm --filter @saferidepro/shared-types build",
    "build": "nest build",
    "prestart": "corepack pnpm --filter @saferidepro/shared-types build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --config ./jest.config.js --runInBand",
    "test:priority:auth-profile": "jest --config ./jest.config.js --runInBand test/unit/auth/login.use-case.spec.ts test/unit/auth/register-user.use-case.spec.ts test/unit/auth/forgot-password.use-case.spec.ts test/unit/auth/reset-password.use-case.spec.ts test/unit/users/update-current-user.use-case.spec.ts",
    "test:watch": "jest --config ./jest.config.js --watch",
    "test:coverage": "jest --config ./jest.config.js --runInBand --coverage",
    "pretest:db": "corepack pnpm --filter @saferidepro/shared-types build",
    "test:db": "node ./test/scripts/run-db-tests.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "format": "prettier --check \"src/**/*.ts\"",
    "prisma:generate": "node ../../scripts/run-api-prisma.js generate",
    "db:migrate": "node ../../scripts/run-api-prisma.js migrate dev",
    "db:deploy": "node ../../scripts/run-api-prisma.js migrate deploy",
    "db:seed": "node ../../scripts/run-api-prisma.js db seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.0",
    "@prisma/client": "^6.6.0",
    "@saferidepro/shared-types": "workspace:*",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@saferidepro/eslint-config": "workspace:*",
    "@saferidepro/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "prisma": "^6.6.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.0"
  }
}
