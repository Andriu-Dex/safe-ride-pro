generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalUserRole {
  USER
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING_EMAIL_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum MembershipRole {
  STUDENT
  INSTITUTION_ADMIN
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DriverVerificationStatus {
  NOT_REQUESTED
  PENDING_VERIFICATION
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocumentType {
  NATIONAL_ID
  PASSPORT
}

enum VehicleType {
  MOTORCYCLE
  CAR
  PICKUP_TRUCK
}

enum LuggagePolicy {
  NOT_ALLOWED
  SMALL_ONLY
  UP_TO_MEDIUM
  LARGE_ALLOWED
}

enum TripStatus {
  DRAFT
  PUBLISHED
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripLiveTrackingStatus {
  READY
  ACTIVE
  ENDED
}

enum TripRouteMode {
  DIRECT_ROUTE
  PLANNED_DETOUR
}

enum TripRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  NO_SHOW
}

enum TripRequestExecutionStatus {
  ACCEPTED_PENDING_BOARDING
  ON_BOARD
  DROPPED_OFF
  NO_SHOW
  CANCELLED_BEFORE_BOARDING
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum OperationalSanctionType {
  WARNING
  LIMITED_PASSENGER
  LIMITED_DRIVER
  SUSPENDED
}

enum OperationalSanctionScope {
  PASSENGER
  DRIVER
  ALL
}

enum OperationalSanctionStatus {
  ACTIVE
  EXPIRED
}

enum OperationalSanctionAppealStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OperationalSanctionTrigger {
  PASSENGER_NO_SHOW
  LATE_DRIVER_CANCELLATION
  LATE_PASSENGER_CANCELLATION
  RESOLVED_REPORTS
}

enum AuditAction {
  AUTH_REGISTERED
  AUTH_EMAIL_VERIFIED
  AUTH_VERIFICATION_CODE_RESENT
  AUTH_LOGIN_SUCCEEDED
  AUTH_LOGIN_FAILED
  AUTH_PASSWORD_RESET_REQUESTED
  AUTH_PASSWORD_RESET_COMPLETED
  AUTH_SESSION_REFRESHED
  AUTH_LOGGED_OUT
  DRIVER_APPLICATION_SUBMITTED
  DRIVER_APPLICATION_APPROVED
  DRIVER_APPLICATION_REJECTED
  TRIP_CREATED
  TRIP_PUBLISHED
  TRIP_STARTED
  TRIP_PASSENGER_BOARDED
  TRIP_PASSENGER_DROPPED_OFF
  TRIP_COMPLETED
  TRIP_CANCELLED
  REPORT_CREATED
  REPORT_REVIEWED
  SANCTION_APPLIED
  SANCTION_EXPIRED
  SANCTION_APPEAL_SUBMITTED
  SANCTION_APPEAL_APPROVED
  SANCTION_APPEAL_REJECTED
  SANCTION_LIFTED_MANUALLY
}

enum AuditEntityType {
  USER
  USER_MEMBERSHIP
  DRIVER_PROFILE
  TRIP
  REPORT
  OPERATIONAL_SANCTION
  SANCTION_APPEAL
  AUTH_SESSION
}

enum AssetStorageProvider {
  IMGUR
}

model Institution {
  id          String                      @id @default(uuid())
  name        String
  code        String                      @unique
  isActive    Boolean                     @default(true)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  domains     InstitutionDomain[]
  memberships UserInstitutionMembership[]
  trips       Trip[]
  auditEvents AuditEvent[]

  @@map("institutions")
}

model InstitutionDomain {
  id            String      @id @default(uuid())
  institutionId String
  domain        String      @unique
  isPrimary     Boolean     @default(false)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, domain])
  @@map("institution_domains")
}

model User {
  id                     String                      @id @default(uuid())
  email                  String                      @unique
  passwordHash           String
  fullName               String
  career                 String?
  phone                  String?
  referenceNeighborhood  String?
  documentType           DocumentType
  documentNumber         String
  profilePhotoUrl        String?
  profilePhotoStorageProvider AssetStorageProvider?
  profilePhotoStorageKey String?
  globalRole             GlobalUserRole              @default(USER)
  accountStatus          AccountStatus               @default(PENDING_EMAIL_VERIFICATION)
  emailVerifiedAt        DateTime?
  termsAcceptedAt        DateTime?
  privacyAcceptedAt      DateTime?
  safetyRulesAcceptedAt  DateTime?
  onboardingCompletedAt  DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  memberships            UserInstitutionMembership[]
  emailVerificationCodes EmailVerificationCode[]
  passwordResetCodes     PasswordResetCode[]
  refreshTokenSessions   RefreshTokenSession[]
  reviewedDriverProfiles DriverProfile[]             @relation("DriverProfileReviewedBy")
  reviewedReports        Report[]                    @relation("ReportReviewedBy")
  requestedSanctionAppeals OperationalSanctionAppeal[] @relation("SanctionAppealRequestedBy")
  reviewedSanctionAppeals OperationalSanctionAppeal[] @relation("SanctionAppealReviewedBy")
  auditEvents            AuditEvent[]                @relation("AuditActor")

  @@unique([documentType, documentNumber])
  @@map("users")
}

model UserInstitutionMembership {
  id                       String                   @id @default(uuid())
  userId                   String
  institutionId            String
  role                     MembershipRole           @default(STUDENT)
  membershipStatus         MembershipStatus         @default(ACTIVE)
  studentCode              String
  isDefault                Boolean                  @default(false)
  driverVerificationStatus DriverVerificationStatus @default(NOT_REQUESTED)
  joinedAt                 DateTime                 @default(now())
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  user                     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution              Institution              @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  driverProfile            DriverProfile?
  vehicles                 Vehicle[]
  driverTrips              Trip[]
  passengerTripRequests    TripRequest[]
  ratingsGiven             Rating[]                 @relation("RatingAuthor")
  ratingsReceived          Rating[]                 @relation("RatingTarget")
  reportsCreated           Report[]                 @relation("ReportReporter")
  reportsReceived          Report[]                 @relation("ReportReported")
  operationalSanctions     OperationalSanction[]

  @@unique([userId, institutionId])
  @@unique([institutionId, studentCode])
  @@map("user_institution_memberships")
}

model EmailVerificationCode {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("email_verification_codes")
}

model PasswordResetCode {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, usedAt, expiresAt])
  @@map("password_reset_codes")
}

model RefreshTokenSession {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("refresh_token_sessions")
}

model LicenseType {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  driverProfiles DriverProfile[]

  @@map("license_types")
}

model DriverProfile {
  id                      String                    @id @default(uuid())
  membershipId            String                    @unique
  licenseTypeId           String
  licenseNumber           String                    @unique
  licenseExpiresAt        DateTime
  identityDocumentFileKey String?
  licenseDocumentFileKey  String?
  reviewNotes             String?
  submittedAt             DateTime                  @default(now())
  reviewedAt              DateTime?
  reviewedByUserId        String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  membership              UserInstitutionMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  licenseType             LicenseType               @relation(fields: [licenseTypeId], references: [id], onDelete: Restrict)
  reviewedByUser          User?                     @relation("DriverProfileReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([licenseTypeId])
  @@map("driver_profiles")
}

model VehicleBrand {
  id        String         @id @default(uuid())
  name      String         @unique
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  models    VehicleModel[]
  vehicles  Vehicle[]

  @@map("vehicle_brands")
}

model VehicleModel {
  id          String         @id @default(uuid())
  brandId     String
  name        String
  vehicleType VehicleType
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  brand       VehicleBrand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  vehicles    Vehicle[]

  @@unique([brandId, name, vehicleType])
  @@index([brandId, vehicleType, isActive])
  @@map("vehicle_models")
}

model Vehicle {
  id                          String                    @id @default(uuid())
  membershipId                String
  vehicleType                 VehicleType
  brandId                     String?
  modelId                     String?
  customBrandName             String?
  customModelName             String?
  year                        Int
  color                       String
  plate                       String                    @unique
  seatCount                   Int
  luggagePolicy               LuggagePolicy
  registrationDocumentFileKey String?
  isActive                    Boolean                   @default(true)
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  membership                  UserInstitutionMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  brand                       VehicleBrand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  model                       VehicleModel?             @relation(fields: [modelId], references: [id], onDelete: SetNull)
  trips                       Trip[]

  @@index([membershipId, isActive])
  @@index([brandId])
  @@index([modelId])
  @@map("vehicles")
}

model Trip {
  id                       String                    @id @default(uuid())
  institutionId            String
  driverMembershipId       String
  vehicleId                String
  status                   TripStatus                @default(DRAFT)
  routeMode                TripRouteMode
  originLabel              String
  destinationLabel         String
  originLatitude           Float                     @db.DoublePrecision
  originLongitude          Float                     @db.DoublePrecision
  destinationLatitude      Float                     @db.DoublePrecision
  destinationLongitude     Float                     @db.DoublePrecision
  departureAt              DateTime
  estimatedArrivalAt       DateTime
  seatCount                Int
  availableSeats           Int
  vehicleTypeSnapshot      VehicleType
  luggagePolicySnapshot    LuggagePolicy
  basePriceReference       Decimal                   @db.Decimal(10, 2)
  detourSurchargeReference Decimal?                  @db.Decimal(10, 2)
  notes                    String?
  cancelledAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  institution              Institution               @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  driverMembership         UserInstitutionMembership @relation(fields: [driverMembershipId], references: [id], onDelete: Cascade)
  vehicle                  Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  tripRequests             TripRequest[]
  liveTracking             TripLiveTracking?
  ratings                  Rating[]
  reports                  Report[]

  @@index([institutionId, status, departureAt])
  @@index([driverMembershipId, departureAt, estimatedArrivalAt])
  @@index([vehicleId, departureAt])
  @@map("trips")
}

model TripLiveTracking {
  id                   String                 @id @default(uuid())
  tripId               String                 @unique
  status               TripLiveTrackingStatus @default(READY)
  startedAt            DateTime?
  endedAt              DateTime?
  lastSignalAt         DateTime?
  currentLatitude      Float?                 @db.DoublePrecision
  currentLongitude     Float?                 @db.DoublePrecision
  currentAccuracyMeters Float?                @db.DoublePrecision
  currentHeadingDegrees Float?                @db.DoublePrecision
  currentSpeedKph      Float?                 @db.DoublePrecision
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  trip                 Trip                   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  points               TripLiveTrackingPoint[]

  @@index([status, lastSignalAt])
  @@map("trip_live_trackings")
}

model TripLiveTrackingPoint {
  id               String           @id @default(uuid())
  trackingId       String
  capturedAt       DateTime
  latitude         Float            @db.DoublePrecision
  longitude        Float            @db.DoublePrecision
  accuracyMeters   Float?           @db.DoublePrecision
  headingDegrees   Float?           @db.DoublePrecision
  speedKph         Float?           @db.DoublePrecision
  createdAt        DateTime         @default(now())
  tracking         TripLiveTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  @@index([trackingId, capturedAt])
  @@map("trip_live_tracking_points")
}
model TripRequest {
  id                       String                    @id @default(uuid())
  tripId                   String
  passengerMembershipId    String
  status                   TripRequestStatus         @default(PENDING)
  executionStatus          TripRequestExecutionStatus?
  requestedPickupLatitude  Float?                    @db.DoublePrecision
  requestedPickupLongitude Float?                    @db.DoublePrecision
  requestedDropoffLatitude Float?                    @db.DoublePrecision
  requestedDropoffLongitude Float?                   @db.DoublePrecision
  requestMessage           String?
  reviewNote               String?
  executionStatusUpdatedAt DateTime?
  boardedAt                DateTime?
  droppedOffAt             DateTime?
  createdAt                DateTime                  @default(now())
  reviewedAt               DateTime?
  cancelledAt              DateTime?
  trip                     Trip                      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  passengerMembership      UserInstitutionMembership @relation(fields: [passengerMembershipId], references: [id], onDelete: Cascade)

  @@index([tripId, status, createdAt])
  @@index([tripId, executionStatus, createdAt])
  @@index([passengerMembershipId, status, createdAt])
  @@index([tripId, passengerMembershipId])
  @@map("trip_requests")
}

model Rating {
  id                 String                    @id @default(uuid())
  tripId             String
  authorMembershipId String
  targetMembershipId String
  score              Int
  comment            String?
  createdAt          DateTime                  @default(now())
  trip               Trip                      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  authorMembership   UserInstitutionMembership @relation("RatingAuthor", fields: [authorMembershipId], references: [id], onDelete: Cascade)
  targetMembership   UserInstitutionMembership @relation("RatingTarget", fields: [targetMembershipId], references: [id], onDelete: Cascade)

  @@unique([tripId, authorMembershipId, targetMembershipId])
  @@index([authorMembershipId, createdAt])
  @@index([targetMembershipId, createdAt])
  @@index([tripId, createdAt])
  @@map("ratings")
}

model Report {
  id                   String                    @id @default(uuid())
  tripId               String
  reporterMembershipId String
  reportedMembershipId String
  status               ReportStatus              @default(PENDING)
  reason               String
  description          String?
  evidenceFileKey      String?
  reviewNote           String?
  reviewedAt           DateTime?
  reviewedByUserId     String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  trip                 Trip                      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  reporterMembership   UserInstitutionMembership @relation("ReportReporter", fields: [reporterMembershipId], references: [id], onDelete: Cascade)
  reportedMembership   UserInstitutionMembership @relation("ReportReported", fields: [reportedMembershipId], references: [id], onDelete: Cascade)
  reviewedByUser       User?                     @relation("ReportReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([tripId, reporterMembershipId, reportedMembershipId])
  @@index([status, createdAt])
  @@index([reporterMembershipId, createdAt])
  @@index([reportedMembershipId, createdAt])
  @@index([tripId, createdAt])
  @@map("reports")
}

model OperationalSanction {
  id           String                    @id @default(uuid())
  membershipId String
  type         OperationalSanctionType
  scope        OperationalSanctionScope
  status       OperationalSanctionStatus @default(ACTIVE)
  trigger      OperationalSanctionTrigger
  reason       String
  isAutomatic  Boolean                   @default(true)
  startedAt    DateTime                  @default(now())
  endsAt       DateTime?
  expiredAt    DateTime?
  metadata     Json?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  membership   UserInstitutionMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  appeal       OperationalSanctionAppeal?

  @@index([membershipId, status])
  @@index([membershipId, scope, status])
  @@index([status, endsAt])
  @@map("operational_sanctions")
}

model OperationalSanctionAppeal {
  id                String                          @id @default(uuid())
  sanctionId        String                          @unique
  requestedByUserId String
  reason            String
  status            OperationalSanctionAppealStatus @default(PENDING)
  reviewNote        String?
  reviewedAt        DateTime?
  reviewedByUserId  String?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt
  sanction          OperationalSanction             @relation(fields: [sanctionId], references: [id], onDelete: Cascade)
  requestedByUser   User                            @relation("SanctionAppealRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedByUser    User?                           @relation("SanctionAppealReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requestedByUserId, status, createdAt])
  @@map("operational_sanction_appeals")
}

model AuditEvent {
  id            String          @id @default(uuid())
  institutionId String?
  actorUserId   String?
  action        AuditAction
  entityType    AuditEntityType
  entityId      String?
  metadata      Json?
  createdAt     DateTime        @default(now())
  institution   Institution?    @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  actorUser     User?           @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([institutionId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("audit_events")
}
